# - .env.dev
# - .env.qa
# - .env.prod
# - .env.local
# - .env.<env>.local
#
# The list below is a reference of currently expected keys across tests/helpers.
# Keep dummy placeholder values only.
# -----------------------------------------------------------------------------
PATIENT_USER_USERNAME=dummy.patient@example.com
PATIENT_USER_PASSWORD=dummy_password
PATIENT_USER_USERNAME_ID=dummy-patient-user-id
PATIENT_USER_USERNAME_RELATED_ID=dummy-patient-related-id
PATIENT_USER_USENAME_CARDID=dummy-patient-card-id

ADMIN_USERNAME=dummy.admin@example.com
ADMIN_PASSWORD=dummy_password

RIDER_USERNAME=dummy.rider@example.com
RIDER_PASSWORD=dummy_password
RIDER_USERID=dummy-rider-user-id

PHARMACIST_USERNAME_REG01=dummy.pharmacist.reg01@example.com
PHARMACIST_PASSWORD_REG01=dummy_password
PHARMACIST_REUSABLE_ORDERID_REG01=dummy-reusable-orderid-reg01
PHARMACIST_BRANCHID_REG01=dummy-branchid-reg01
PHARMACIST_PHONENUMBER_REG01=09170000001

PHARMACIST_USERNAME_REG02=dummy.pharmacist.reg02@example.com
PHARMACIST_PASSWORD_REG02=dummy_password
PHARMACIST_BRANCHID_REG02=dummy-branchid-reg02
PHARMACIST_PHONENUMBER_REG02=09170000002

PHARMACIST_USERNAME_PSE01=dummy.pharmacist.pse01@example.com
PHARMACIST_PASSWORD_PSE01=dummy_password
PHARMACIST_BRANCHID_PSE01=dummy-branchid-pse01

PHARMACIST_USERNAME_ADMIN=dummy.pharmacist.admin@example.com
PHARMACIST_PASSWORD_ADMIN=dummy_password

MERCHANT_USERNAME=dummy.merchant@example.com
MERCHANT_PASSWORD=dummy_password

MEDEX_USERNAME=dummy.medex@example.com
MEDEX_PASSWORD=dummy_password
