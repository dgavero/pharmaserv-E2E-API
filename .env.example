# Shared runtime config reference.
# Put real values in your local .env, .env.<env>, or .env.<env>.local files.
# Keep dummy values here only; do not place real credentials in this file.
#
# Load order in playwright.config.js:
# 1. .env
# 2. .env.<test_env>
# 3. .env.local
# 4. .env.<test_env>.local
#
# Shell and CI variables override file values.

# -----------------------------------------------------------------------------
# Core Runtime Selection
# Consumed by:
# - playwright.config.js
# - api/globalConfig.api.js
# - e2e/globalConfig.ui.js
# - scripts/ci/*
# - helpers/discord/*
# Valid values:
# - TEST_ENV: DEV | QA | PROD
# - PROJECT / PROJECTS: api | e2e | api,e2e | e2e,api
# - HEADLESS: true | false
# - REPORT_PUBLISH: 0 | 1
# -----------------------------------------------------------------------------
TEST_ENV=DEV
PROJECT=
PROJECTS=
TAGS=
THREADS=4
HEADLESS=false
CI=false
REPORT_PUBLISH=1
PW_BLOB_OUTPUT=
DISCORD_REUSE_RUN=0
DISCORD_GREP_LABEL=
DISCORD_BATCH_INDEX=1
DISCORD_BATCH_COUNT=1
DRY_RUN=0

# -----------------------------------------------------------------------------
# Base URLs
# Consumed by:
# - playwright.config.js
# - api/globalConfig.api.js
# - e2e/globalConfig.ui.js
# Notes:
# - BASE_URL is an optional explicit UI fallback.
# - API_BASE_URL is an optional explicit API fallback/override.
# -----------------------------------------------------------------------------
BASE_URL=https://dev-ui.example.com/
BASE_URL_DEV=https://dev-ui.example.com/
BASE_URL_QA=https://qa-ui.example.com/
BASE_URL_PROD=https://prod-ui.example.com/

API_BASE_URL=https://dev-api.example.com
API_BASE_URL_DEV=https://dev-api.example.com
API_BASE_URL_QA=https://qa-api.example.com
API_BASE_URL_PROD=https://prod-api.example.com

# -----------------------------------------------------------------------------
# GraphQL / Legacy API
# Consumed by:
# - api/helpers/graphqlClient.js
# - legacy API-oriented tests and helpers
# -----------------------------------------------------------------------------
API_BASE_LEGACY=http://legacy-api.example.com:8080
GRAPHQL_PATH=/api/v1/pharmaserv/graphql

# -----------------------------------------------------------------------------
# Discord / Report Routing
# Consumed by:
# - helpers/discord/discordBot.js
# - helpers/discord/discordSetup.js
# - e2e/helpers/reporting/discordReporterClient.js
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=dummy_discord_bot_token
DEV_TESTING_CHANNELID=111111111111111111
QA_TESTING_CHANNELID=222222222222222222
PROD_TESTING_CHANNELID=333333333333333333
LOCAL_RUNS_CHANNELID=444444444444444444

# -----------------------------------------------------------------------------
# Docker / Local Runner Helpers
# Consumed by:
# - scripts/ci/docker-run.cjs
# - scripts/ci/run-tests-in-docker.cjs
# - scripts/ci/run-tests-in-docker.sh
# Valid values:
# - MODE: basic | regression | stress
# -----------------------------------------------------------------------------
MODE=basic
RUN_TAGS=
DOCKER_IMAGE=pharmaserv-tests
ENV_FILE=
EVENT_NAME=workflow_dispatch

# -----------------------------------------------------------------------------
# Rerun Helper / GitHub Integration
# Consumed by:
# - helpers/rerun/rerunPayload.js
# - scripts/rerun-helper/server.cjs
# - scripts/ci/publish-report.js
# Notes:
# - Local runs usually do not need these.
# - CI typically injects GITHUB_* values.
# -----------------------------------------------------------------------------
RERUN_HELPER_BASE_URL=http://localhost:8787/
RERUN_HELPER_SIGNING_SECRET=dummy_rerun_secret
RERUN_HELPER_HOST=0.0.0.0
RERUN_HELPER_PORT=8787
RERUN_HELPER_GITHUB_API_BASE=https://api.github.com
RERUN_HELPER_GITHUB_TOKEN=dummy_github_token
GITHUB_TOKEN=dummy_github_token
GH_TOKEN=dummy_github_token
GH_PAGES_TOKEN=dummy_github_token
GITHUB_REF=refs/heads/main
GITHUB_REPOSITORY=your-org/pharmaserv-E2E-API
GITHUB_ENV=
GITHUB_ACTIONS=false
GIT_AUTHOR_NAME=Local User
GIT_AUTHOR_EMAIL=local@example.com
GIT_COMMITTER_NAME=Local User
GIT_COMMITTER_EMAIL=local@example.com

# -----------------------------------------------------------------------------
# Secrets Tooling
# Consumed by:
# - scripts/secrets/build-encrypted-files.js
# - scripts/secrets/install-crypto-tools.cjs
# - scripts/secrets/load-secrets.js
# -----------------------------------------------------------------------------
SOPS_AGE_RECIPIENTS=age1examplepublicrecipientkeyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOPS_AGE_KEY=AGE-SECRET-KEY-EXAMPLEXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SOPS_VERSION=3.10.2
AGE_VERSION=1.2.1

# -----------------------------------------------------------------------------
# Debug / Manual Maintenance
# Consumed by:
# - api/tests/e2e/shared/steps/pharmacist.steps.js
# - api/tests/testData/healReusableIds.spec.js
# - scripts/heal-reusable-ids.cjs
# -----------------------------------------------------------------------------
DEBUG_WORKFLOW_IDS=0
HEAL_SLOT=

# -----------------------------------------------------------------------------
# Credentials and environment-specific test data
